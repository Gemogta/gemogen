{
  "name": "gemogen/gemogen",
  "description": "Scenario-based content generator for WordPress development",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Gemogen\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Gemogen\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite=unit",
    "test:integration": "phpunit --testsuite=integration",
    "gemogen:list": "wp gemogen list",
    "gemogen:run": "wp gemogen run",
    "gemogen:info": "wp gemogen info",
    "gemogen:rollback": "wp gemogen rollback"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
